// Custom styles for NexT theme.
// Loaded via theme.custom_file_path.style in themes/next-reloaded/_config.yml.

// Sidebar avatar: round + hover spin animation.
// Origin: https://www.jianshu.com/p/d34e9531cfce
.site-author-image {
  border-radius: 50%;
  -webkit-transition: 1.4s all;
  -moz-transition: 1.4s all;
  -ms-transition: 1.4s all;
  transition: 1.4s all;
}

.site-author-image:hover {
  background-color: #55DAE1;
  -webkit-transform: rotate(360deg) scale(0.9);
  -moz-transform: rotate(360deg) scale(0.9);
  -ms-transform: rotate(360deg) scale(0.9);
  transform: rotate(360deg) scale(0.9);
}

// Card-like post container with soft shadow.
.post {
  margin-top: 60px;
  margin-bottom: 60px;
  padding: 25px;
  -webkit-box-shadow: 0 0 5px rgba(202, 203, 203, 0.5);
  -moz-box-shadow: 0 0 5px rgba(202, 203, 204, 0.5);
  box-shadow: 0 0 5px rgba(202, 203, 203, 0.5);
}

// Dark mode — auto-follows OS / browser preference, matching giscus theme.
@media (prefers-color-scheme: dark) {
  // Page chrome
  body,
  .header,
  .header-inner,
  .main,
  .container,
  .sidebar,
  .footer {
    background: #1f2227;
    color: #d0d4d9;
  }

  .header-inner,
  .sidebar-inner {
    background: #2a2e34;
  }

  // Post card
  .post,
  .post-block,
  .posts-expand .post-block {
    background: #2a2e34;
    color: #d0d4d9;
    box-shadow: 0 0 5px rgba(0, 0, 0, 0.6);
  }

  // Headings
  h1, h2, h3, h4, h5, h6,
  .post-title,
  .post-title-link,
  .menu-item a,
  .site-meta .brand,
  .site-meta .custom-logo-image,
  .site-author-name,
  .site-description,
  strong, b {
    color: #f0f3f7;
  }

  // Links — subtle blue, not eye-piercing
  a,
  a:visited,
  .post-meta a,
  .post-tags a,
  .menu-item a:hover,
  .toc-link {
    color: #87b3e8;
  }

  a:hover {
    color: #b3d1f5;
  }

  // Inline code
  code {
    background: #383d44;
    color: #e6e6e6;
  }

  // Code blocks — leave the syntax highlight theme alone, just darken the wrapper
  pre,
  .highlight,
  figure.highlight,
  .codeblock {
    background: #1a1d22;
    color: #d0d4d9;
  }

  .highlight .gutter,
  figure.highlight .gutter {
    background: #14171c;
  }

  // Blockquotes — used by the "待补充" placeholders in the post draft
  blockquote {
    background: #262a30;
    border-left-color: #55dae1;
    color: #b8bdc4;
  }

  // Tables
  table,
  th,
  td {
    background: #2a2e34;
    color: #d0d4d9;
    border-color: #3a3f47;
  }

  // Search popup, post copyright box, footer text
  .popup,
  .post-copyright,
  .post-nav,
  .pagination .page-number {
    background: #262a30;
    color: #d0d4d9;
    border-color: #3a3f47;
  }

  // Sidebar TOC active item
  .post-toc .nav .active > a {
    color: #87b3e8;
  }

  // Horizontal rules / dividers
  hr {
    border-color: #3a3f47;
  }

  // Form inputs (search box, comment input)
  input,
  textarea {
    background: #1f2227;
    color: #d0d4d9;
    border-color: #3a3f47;
  }

  // Footer copyright softens
  .copyright,
  .powered-by,
  .theme-info {
    color: #888d94;
  }
}

