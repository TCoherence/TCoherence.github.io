// Custom styles for NexT theme.
// Loaded via theme.custom_file_path.style in themes/next-reloaded/_config.yml.

// Sidebar avatar: round + hover spin animation.
// Origin: https://www.jianshu.com/p/d34e9531cfce
.site-author-image {
  border-radius: 50%;
  -webkit-transition: 1.4s all;
  -moz-transition: 1.4s all;
  -ms-transition: 1.4s all;
  transition: 1.4s all;
}

.site-author-image:hover {
  background-color: #55DAE1;
  -webkit-transform: rotate(360deg) scale(0.9);
  -moz-transform: rotate(360deg) scale(0.9);
  -ms-transform: rotate(360deg) scale(0.9);
  transform: rotate(360deg) scale(0.9);
}

// Card-like post container with soft shadow.
.post {
  margin-top: 60px;
  margin-bottom: 60px;
  padding: 25px;
  -webkit-box-shadow: 0 0 5px rgba(202, 203, 203, 0.5);
  -moz-box-shadow: 0 0 5px rgba(202, 203, 204, 0.5);
  box-shadow: 0 0 5px rgba(202, 203, 203, 0.5);
}

// Dark-mode patches for things NexT 7.8 hardcoded outside its CSS-var system.
// (NexT's darkmode rewrites :root vars but `code` and `.highlight` use
// literal #eee / #f7f7f7 backgrounds that don't switch.)
@media (prefers-color-scheme: dark) {
  // Inline code: `~/.slock/agents/<uuid>/`, `MEMORY.md`, etc.
  code {
    background: #2c2f36;
    color: #e6e6e6;
  }

  // Code blocks (Hexo highlight + plain pre).
  .highlight,
  pre {
    background: #1a1d22;
    color: #d0d4d9;
  }

  // Hexo's highlighter wraps fenced blocks in
  //   <figure class="highlight"><table><tr>
  //     <td class="gutter"><pre>line numbers</pre></td>
  //     <td class="code"><pre>actual code</pre></td>
  //   </tr></table></figure>
  // The inner `.highlight .code pre` rule (specificity 0,2,1) shadows our
  // `pre` rule (0,0,1) and re-applies the default `#f7f7f7`, which is why
  // a fenced block looks white-on-dark in dark mode without these overrides.
  .highlight .code pre {
    background: #1a1d22;
    color: #d0d4d9;
  }

  // Line-number gutter inside Hexo's highlight tables.
  .highlight .gutter,
  figure.highlight .gutter {
    background: #14171c;
  }
  .highlight .gutter pre {
    background: #14171c;
    color: #6b7280;
  }

  // Caption row above the table (lang label / copy button host).
  .highlight figcaption {
    background: #14171c;
    color: #b8bdc4;
  }

  // Mermaid v8 dark theme darkens nodes but leaves the SVG canvas white.
  // Force the wrapper + SVG to a dark background.
  pre.mermaid,
  pre.mermaid svg {
    background: #1f2227 !important;
  }

  // Reports hub cards in dark mode.
  .reports-card {
    background: #2a2e34 !important;
    border-color: #3a3f47 !important;
  }
  .reports-card:hover {
    background: #323841 !important;
    border-color: #55dae1 !important;
  }
  .reports-card-meta,
  .reports-card-latest,
  .reports-card-desc {
    color: #b8bdc4 !important;
  }

  // "今日更新" strip in dark mode.
  .reports-today {
    background: #1f2227 !important;
    border-left-color: #55dae1 !important;
  }
  .reports-today-header {
    color: #f0f3f7 !important;
  }
  .reports-today-tag {
    background: #1c3a3d !important;
    color: #7ce6ec !important;
  }
  .reports-today-list a {
    border-bottom-color: #4a5060 !important;
  }
  .reports-today-more {
    background: #2a2e34 !important;
    color: #b8bdc4 !important;
  }
  .reports-today-more:hover {
    background: #1c3a3d !important;
    color: #7ce6ec !important;
  }
}

// AI 报告 hub landing page.
.reports-hub-intro {
  margin-bottom: 24px;
  font-size: 0.95em;
  color: #666;
  line-height: 1.7;
}

// "今日更新" quick-jump strip — shown only when at least one report has
// today's date. Each row is a short chip + linked title.
.reports-today {
  margin: 0 0 30px;
  padding: 16px 18px 14px;
  background: #f5fbfb;
  border-left: 3px solid #55dae1;
  border-radius: 4px;
}

.reports-today-header {
  font-weight: 600;
  font-size: 0.95em;
  color: #2a2e34;
  margin-bottom: 10px;
}

.reports-today-header i {
  color: #55dae1;
  margin-right: 6px;
}

.reports-today-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.reports-today-list li {
  margin: 6px 0;
  font-size: 0.92em;
  display: flex;
  align-items: baseline;
  gap: 10px;
}

.reports-today-tag {
  display: inline-block;
  min-width: 4em;
  padding: 1px 8px;
  font-size: 0.82em;
  background: #e0f5f6;
  color: #00838c;
  border-radius: 3px;
  text-align: center;
  flex-shrink: 0;
}

.reports-today-list a {
  color: inherit;
  text-decoration: none;
  border-bottom: 1px dashed #bbb;
}

.reports-today-list a:hover {
  color: #55dae1;
  border-bottom-color: #55dae1;
}

.reports-today-more {
  margin-left: 8px;
  padding: 1px 7px;
  font-size: 0.78em;
  background: #f0f0f0;
  color: #666 !important;
  border-radius: 3px;
  border-bottom: none !important;
  white-space: nowrap;
}

.reports-today-more:hover {
  background: #e0f5f6;
  color: #00838c !important;
  border-bottom: none !important;
}

.reports-hub-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 18px;
  margin-top: 10px;
}

.reports-card {
  display: flex;
  flex-direction: column;
  padding: 22px;
  background: #fafafa;
  border: 1px solid #e6e6e6;
  border-radius: 8px;
  text-decoration: none;
  color: inherit;
  transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
}

.reports-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
  border-color: #55dae1;
  text-decoration: none;
}

.reports-card-icon {
  font-size: 1.8em;
  color: #55dae1;
  margin-bottom: 10px;
}

.reports-card-title {
  font-size: 1.25em;
  font-weight: 600;
  margin-bottom: 6px;
  color: inherit;
}

.reports-card-meta {
  font-size: 0.85em;
  color: #888;
  margin-bottom: 4px;
}

.reports-card-latest {
  font-size: 0.85em;
  color: #999;
  margin-bottom: 10px;
}

.reports-card-desc {
  font-size: 0.9em;
  color: #555;
  line-height: 1.5;
  margin-top: auto;
}
