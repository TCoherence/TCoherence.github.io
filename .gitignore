.DS_Store
Thumbs.db
db.json
search.json
search.xml
*.log
node_modules/
public/
.deploy*/
.claude/

# AI 报告：每次 build 由 scripts/sync-ai-reports.js 从 oh-my-agent dir
# 重新生成；watermark 也是 derived 状态。
/source/_posts/ai-reports/
/.cache/
themes/*
!themes/next-reloaded

# Hexo renders into public/, but if anyone runs the deploy script from
# the wrong dir, these can leak into the repo root. Block them.
/index.html
/about/
/archives/
/categories/
/tags/
/2018/
/2019/
/2020/
/2021/
/2022/
/2023/
/2024/
/2025/
/2026/
/css/
/js/
/lib/
/images/

# Never commit private keys / credentials
mykey
mykey.pub
*.pem
*.key
id_rsa*
id_ed25519*
id_ecdsa*
*.pkcs12
*.p12
.env
.env.*
